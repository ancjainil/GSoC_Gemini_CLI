{
  "name": "@gemini-cli/eval-framework",
  "version": "0.1.0",
  "description": "Behavioral Evaluation Test Framework for Gemini CLI",
  "author": "Jainil Rana <jainilrana503@gmail.com>",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "RUN_EVALS=1 vitest run scenarios/",
    "eval:nightly": "RUN_EVALS=1 EVAL_RUNS=5 vitest run scenarios/",
    "report": "tsx src/cli/generate-report.ts",
    "check-regressions": "tsx src/cli/check-regressions.ts"
  },
  "dependencies": {
    "vitest": "^1.6.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0"
  },
  "files": [
    "dist/",
    "scenarios/",
    "baselines/"
  ]
}
